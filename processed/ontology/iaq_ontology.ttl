@prefix : <http://example.org/iaq.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix quantitykind: <http://qudt.org/vocab/quantitykind/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/iaq.owl> a owl:Ontology .

:Dangerous a :AirQualityState,
        owl:NamedIndividual .

:Excellent a :AirQualityState,
        owl:NamedIndividual .

:Good a :AirQualityState,
        owl:NamedIndividual .

:Moderate a :AirQualityState,
        owl:NamedIndividual .

:Poor a :AirQualityState,
        owl:NamedIndividual .

:TimeContext a owl:Class ;
    rdfs:subClassOf owl:Thing,
        time:TemporalEntity .

:associatedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain :AirProperty ;
    rdfs:range :AirProperty .

:atLocation a owl:ObjectProperty ;
    rdfs:domain :Observation ;
    rdfs:range :Location ;
    rdfs:subPropertyOf sosa:hasFeatureOfInterest .

:correlatedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain :AirProperty ;
    rdfs:range :AirProperty .

:duringEvent a owl:ObjectProperty ;
    rdfs:domain :Observation ;
    rdfs:range :AnomalyEvent .

:endTime a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:range xsd:string .

:eventAtLocation a owl:ObjectProperty ;
    rdfs:domain :AnomalyEvent ;
    rdfs:range :Location .

:hasDangerFlag a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:range xsd:boolean .

:hasMeasurement a owl:ObjectProperty ;
    rdfs:domain :Observation ;
    rdfs:range :Measurement ;
    rdfs:subPropertyOf sosa:hasMember .

:hasNormalizedValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:range xsd:decimal .

:hasState a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:range xsd:string .

:hasTimestampValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:comment "Aligned with sosa:resultTime"^^xsd:string ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf sosa:resultTime .

:hasUnit a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:range xsd:string .

:hasValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:comment "Aligned with sosa:hasSimpleResult"^^xsd:string ;
    rdfs:range xsd:decimal ;
    rdfs:subPropertyOf qudt:value .

:influences a owl:ObjectProperty ;
    rdfs:domain :AirProperty ;
    rdfs:range :AirProperty .

