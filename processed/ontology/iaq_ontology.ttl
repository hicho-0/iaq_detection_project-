:reflects a owl:ObjectProperty ;
    rdfs:domain :AirProperty ;
    rdfs:range owl:Thing .

:AcousticCondition a owl:Class ;
    rdfs:subClassOf :AirProperty .

:AssessmentMetric a owl:Class ;
    rdfs:subClassOf :AirProperty .

:CarbonMonoxide a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :causes ;
            owl:someValuesFrom :HealthRisk ],
        :Pollutant .

:DynamicCondition a owl:Class ;
    rdfs:subClassOf :AirProperty .

:NitrogenDioxide a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affects ;
            owl:someValuesFrom :RespiratoryRisk ],
        :Pollutant .

:PM10 a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affects ;
            owl:someValuesFrom :RespiratoryRisk ],
        :ParticleMatter .

:PM2_5 a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affects ;
            owl:someValuesFrom :RespiratoryRisk ],
        :ParticleMatter .

:causes a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range :Condition .

:Condition a owl:Class ;
    rdfs:subClassOf owl:Thing .

:Location a owl:Class ;
    rdfs:comment "Aligned with sosa:FeatureOfInterest"^^xsd:string ;
    rdfs:subClassOf owl:Thing,
        sosa:FeatureOfInterest .

:increases a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range :AirProperty .

:AnomalyEvent a owl:Class ;
    rdfs:subClassOf owl:Thing .

:ParticleMatter a owl:Class ;
    rdfs:subClassOf :AirProperty .

:RespiratoryRisk a owl:Class ;
    rdfs:subClassOf :Condition .

:ParticleCount a owl:Class ;
    rdfs:subClassOf :AirProperty .

:Pollutant a owl:Class ;
    rdfs:subClassOf :AirProperty .

:EnvironmentalCondition a owl:Class ;
    rdfs:subClassOf :AirProperty .

:affects a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:AirQualityState a owl:Class ;
    rdfs:subClassOf owl:Thing .

:AirProperty a owl:Class ;
    rdfs:comment "Aligned with sosa:ObservableProperty"^^xsd:string ;
    rdfs:subClassOf owl:Thing,
        sosa:ObservableProperty .

:dust_humidity a :HumidityMeasurementError,
        owl:NamedIndividual ;
    :affects :pm1,
        :pm10,
        :pm2_5 ;
    :endTime "2023-07-09 23:59"^^xsd:string ;
    :eventAtLocation :Apartment ;
    :startTime "2023-07-09 00:00"^^xsd:string .

:fire a :FireEvent,
        owl:NamedIndividual ;
    :endTime "2023-05-21 23:59"^^xsd:string ;
    :eventAtLocation :Laboratory ;
    :increases :co,
        :no2,
        :pm1,
        :pm10,
        :pm2_5 ;
    :startTime "2023-05-21 00:00"^^xsd:string .

:power_outage a :PowerOutage,
        owl:NamedIndividual ;
    :endTime "2023-04-19 12:00"^^xsd:string ;
    :eventAtLocation :Laboratory ;
    :startTime "2023-04-17 00:00"^^xsd:string .

:Observation a owl:Class ;
    rdfs:comment "Aligned with sosa:Observation"^^xsd:string ;
    rdfs:subClassOf owl:Thing,
        sosa:ObservationCollection .

:TypPS a :AverageParticleSize,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :pm2_5 ;
    :hasUnit "um"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:Length ;
    qudt:unit unit:MicroM .

:cnt0_3 a :ParticleCount0_3,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :pm1 ;
    :hasUnit "count"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:NumberDensity ;
    qudt:unit unit:NUM-PER-M3 .

:cnt0_5 a :ParticleCount0_5,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :pm1 ;
    :hasUnit "count"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:NumberDensity ;
    qudt:unit unit:NUM-PER-M3 .

:cnt1 a :ParticleCount1,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :pm1 ;
    :hasUnit "count"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:NumberDensity ;
    qudt:unit unit:NUM-PER-M3 .

:cnt10 a :ParticleCount10,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :pm10 ;
    :hasUnit "count"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:NumberDensity ;
    qudt:unit unit:NUM-PER-M3 .

:cnt2_5 a :ParticleCount2_5,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :pm2_5 ;
    :hasUnit "count"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:NumberDensity ;
    qudt:unit unit:NUM-PER-M3 .

:cnt5 a :ParticleCount5,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :pm10 ;
    :hasUnit "count"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:NumberDensity ;
    qudt:unit unit:NUM-PER-M3 .

:dCO2dt a :CO2ChangeRate,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "ppm/s"^^xsd:string ;
    :indicates :co2 .

:dHdt a :HumidityChangeRate,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "g/m3/s"^^xsd:string ;
    :indicates :humidity_abs .

:humidity a :RelativeHumidity,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :dewpt,
        :humidity_abs ;
    :hasUnit "%"^^xsd:string ;
    :influences :pm1,
        :pm10,
        :pm2_5 ;
    qudt:hasQuantityKind quantitykind:RelativeHumidity ;
    qudt:unit unit:PERCENT .

:measuretime a :MeasurementCycle,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :performance ;
    :hasUnit "ms"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:Time ;
    qudt:unit unit:MilliSEC .

:oxygen a :OxygenLevel,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :temperature ;
    :hasUnit "%vol"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:VolumeFraction ;
    qudt:unit unit:PERCENT .

:pressure a :AtmosphericPressure,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "hPa"^^xsd:string ;
    :influences :pm10 ;
    qudt:hasQuantityKind quantitykind:Pressure ;
    qudt:unit unit:HectoPA .

:so2 a :SulfurDioxide,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :no2 ;
    :hasUnit "ug/m3"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:MassConcentration ;
    qudt:unit unit:MicroGM-PER-M3 .

:sound_max a :MaximumNoiseLevel,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :sound ;
    :hasUnit "dB(A)"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:SoundPressureLevel ;
    qudt:unit unit:DeciB .

:co a :CarbonMonoxide,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :co2 ;
    :hasUnit "ppm"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:VolumeFraction ;
    qudt:unit unit:PPM .

:health a :HealthIndex,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "index"^^xsd:string ;
    :reflects :performance .

:sound a :NoiseLevel,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :associatedWith :co2 ;
    :hasUnit "dB(A)"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:SoundPressureLevel ;
    qudt:unit unit:DeciB .

:temperature a :Temperature,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :dewpt,
        :temperature_o2 ;
    :hasUnit "C"^^xsd:string ;
    :influences :o3,
        :tvoc ;
    qudt:hasQuantityKind quantitykind:Temperature ;
    qudt:unit unit:DEG_C .

:temperature_o2 a :OxygenTemperature,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "C"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:Temperature ;
    qudt:unit unit:DEG_C .

:humidity_abs a :AbsoluteHumidity,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :dewpt ;
    :hasUnit "g/m3"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:MassConcentration ;
    qudt:unit unit:GM-PER-M3 .

:no2 a :NitrogenDioxide,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :o3 ;
    :hasUnit "ug/m3"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:MassConcentration ;
    qudt:unit unit:MicroGM-PER-M3 .

:o3 a :Ozone,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "ug/m3"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:MassConcentration ;
    qudt:unit unit:MicroGM-PER-M3 .

:tvoc a :VOC,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "ppb"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:VolumeFraction ;
    qudt:unit unit:PPB .

:co2 a :CarbonDioxide,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :affects :health,
        :performance ;
    :correlatedWith :tvoc ;
    :hasUnit "ppm"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:VolumeFraction ;
    qudt:unit unit:PPM .

:dewpt a :DewPoint,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "C"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:Temperature ;
    qudt:unit unit:DEG_C .

:performance a :PerformanceIndex,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "score"^^xsd:string .

:pm2_5 a :PM2_5,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :pm1,
        :pm10 ;
    :hasUnit "ug/m3"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:MassConcentration ;
    qudt:unit unit:MicroGM-PER-M3 .

:pm1 a :PM1,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :correlatedWith :pm10 ;
    :hasUnit "ug/m3"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:MassConcentration ;
    qudt:unit unit:MicroGM-PER-M3 .

:pm10 a :PM10,
        owl:NamedIndividual,
        sosa:ObservableProperty ;
    :hasUnit "ug/m3"^^xsd:string ;
    qudt:hasQuantityKind quantitykind:MassConcentration ;
    qudt:unit unit:MicroGM-PER-M3 .

:Apartment a :Location,
        owl:NamedIndividual .

:Laboratory a :Location,
        owl:NamedIndividual .

:Measurement a owl:Class ;
    rdfs:comment "Aligned with sosa:Observation result"^^xsd:string ;
    rdfs:subClassOf owl:Thing,
        sosa:Observation .

