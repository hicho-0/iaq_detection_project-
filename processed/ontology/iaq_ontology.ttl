:observedProperty a owl:ObjectProperty ;
    rdfs:domain :Measurement ;
    rdfs:range :AirProperty ;
    rdfs:subPropertyOf sosa:observedProperty .

:startTime a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:range xsd:string .

:AbsoluteHumidity a owl:Class ;
    rdfs:subClassOf :EnvironmentalCondition .

:AtmosphericPressure a owl:Class ;
    rdfs:subClassOf :EnvironmentalCondition .

:AverageParticleSize a owl:Class ;
    rdfs:subClassOf :ParticleMatter .

:CO2ChangeRate a owl:Class ;
    rdfs:subClassOf :DynamicCondition .

:CarbonDioxide a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :indicates ;
            owl:someValuesFrom :PoorVentilation ],
        :Pollutant .

:DewPoint a owl:Class ;
    rdfs:subClassOf :EnvironmentalCondition .

:FireEvent a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :increases ;
            owl:someValuesFrom :NitrogenDioxide ],
        [ a owl:Restriction ;
            owl:onProperty :increases ;
            owl:someValuesFrom :CarbonMonoxide ],
        [ a owl:Restriction ;
            owl:onProperty :increases ;
            owl:someValuesFrom :PM2_5 ],
        [ a owl:Restriction ;
            owl:onProperty :degrades ;
            owl:someValuesFrom :AirQualityState ],
        [ a owl:Restriction ;
            owl:onProperty :increases ;
            owl:someValuesFrom :PM10 ],
        :AnomalyEvent .

:HealthIndex a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :reflects ;
            owl:someValuesFrom :AirQualityState ],
        :AssessmentMetric .

:HealthRisk a owl:Class ;
    rdfs:subClassOf :Condition .

:HumidityChangeRate a owl:Class ;
    rdfs:subClassOf :DynamicCondition .

:HumidityMeasurementError a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affects ;
            owl:someValuesFrom :ParticleMatter ],
        :AnomalyEvent .

:IrritationRisk a owl:Class ;
    rdfs:subClassOf :Condition .

:MaximumNoiseLevel a owl:Class ;
    rdfs:subClassOf :AcousticCondition .

:MeasurementCycle a owl:Class ;
    rdfs:subClassOf :MeasurementProperty .

:MeasurementProperty a owl:Class ;
    rdfs:subClassOf :AirProperty .

:NoiseLevel a owl:Class ;
    rdfs:subClassOf :AcousticCondition .

:OxygenLevel a owl:Class ;
    rdfs:subClassOf :EnvironmentalCondition .

:OxygenTemperature a owl:Class ;
    rdfs:subClassOf :EnvironmentalCondition .

:Ozone a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affects ;
            owl:someValuesFrom :RespiratoryRisk ],
        :Pollutant .

:PM1 a owl:Class ;
    rdfs:subClassOf :ParticleMatter .

:ParticleCount0_3 a owl:Class ;
    rdfs:subClassOf :ParticleCount .

:ParticleCount0_5 a owl:Class ;
    rdfs:subClassOf :ParticleCount .

:ParticleCount1 a owl:Class ;
    rdfs:subClassOf :ParticleCount .

:ParticleCount10 a owl:Class ;
    rdfs:subClassOf :ParticleCount .

:ParticleCount2_5 a owl:Class ;
    rdfs:subClassOf :ParticleCount .

:ParticleCount5 a owl:Class ;
    rdfs:subClassOf :ParticleCount .

:PerformanceIndex a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affectedBy ;
            owl:someValuesFrom :AirQualityState ],
        :AssessmentMetric .

:PoorVentilation a owl:Class ;
    rdfs:subClassOf owl:Thing .

:PowerOutage a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affects ;
            owl:someValuesFrom :Observation ],
        :AnomalyEvent .

:RelativeHumidity a owl:Class ;
    rdfs:subClassOf :EnvironmentalCondition .

:SulfurDioxide a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :affects ;
            owl:someValuesFrom :RespiratoryRisk ],
        :Pollutant .

:Temperature a owl:Class ;
    rdfs:subClassOf :EnvironmentalCondition .

:VOC a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :causes ;
            owl:someValuesFrom :IrritationRisk ],
        :Pollutant .

:affectedBy a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:degrades a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:indicates a owl:ObjectProperty ;
    rdfs:domain :AirProperty ;
    rdfs:range owl:Thing .

